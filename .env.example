# Copy this file to `.env` and fill in real values.
# `cp .env.example .env`

# Generate with: openssl rand -hex 32
# Must be IDENTICAL in both server and agent envs.
WOODPECKER_AGENT_SECRET=replace_me_with_64_hex_chars

# From your GitHub OAuth app:
# https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/authorize
WOODPECKER_GITHUB_CLIENT=your_github_oauth_client_id
WOODPECKER_GITHUB_SECRET=your_github_oauth_client_secret
